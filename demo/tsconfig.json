{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "types": ["vite/client"],
    "paths": {
      "components/*": ["./src/components/*"],
      "ui/*": ["./src/components/ui/*"],
      "pages/*": ["./src/pages/*"],
      "data/*": ["./src/data/*"],
      "lib/*": ["./src/lib/*"],
      "utils": ["./src/lib/utils.ts"],
      "shared/*": ["./shared/*"]
    }
  },
  "include": ["src", "shared", "api", "vite.config.ts"]
}
