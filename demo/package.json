{
  "name": "@finografic/deps-xscan-demo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/ensure-xscan-build.mjs",
    "dev": "concurrently -k -n api,app -c blue,green \"pnpm dev:api\" \"pnpm dev:app\"",
    "dev:api": "tsx watch api/server.ts",
    "dev:app": "vite",
    "build": "tsc --project tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "start:api": "tsx api/server.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.0"
  }
}
