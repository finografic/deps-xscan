{
  "name": "@finografic/deps-xscan-demo",
  "version": "0.0.5",
  "private": false,
  "description": "Embeddable React browser demo for @finografic/deps-xscan.",
  "keywords": [
    "deps-xscan",
    "xscan",
    "react",
    "vite",
    "security",
    "demo"
  ],
  "homepage": "https://github.com/finografic/deps-xscan#readme",
  "bugs": {
    "url": "https://github.com/finografic/deps-xscan/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/deps-xscan.git",
    "directory": "demo"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "src",
    "shared",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./app.css": "./src/app.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "predev": "node scripts/ensure-xscan-build.mjs",
    "dev": "concurrently -k -n api,app -c blue,green \"pnpm dev:api\" \"pnpm dev:app\"",
    "dev:api": "tsx watch api/server.ts",
    "dev:app": "vite",
    "build": "tsc --project tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "·········· PUBLISH:GITHUB": "············································",
    "release:check": "pnpm typecheck && pnpm build && pnpm pack --dry-run",
    "release:github:patch": "pnpm run release:check && tsx ../scripts/release-demo.ts patch",
    "release:github:minor": "pnpm run release:check && tsx ../scripts/release-demo.ts minor",
    "release:github:major": "pnpm run release:check && tsx ../scripts/release-demo.ts major",
    "release:publish": "pnpm publish --no-git-checks --registry https://npm.pkg.github.com",
    "start:api": "tsx api/server.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "node-pty": "^1.1.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.0"
  }
}
