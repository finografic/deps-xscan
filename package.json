{
  "name": "@finografic/deps-xscan",
  "version": "0.6.7",
  "private": false,
  "description": "Dependency security x-scan: cross-checks your resolved dependency tree against OSV, Node.js advisories, and GitHub Advisory / Dependabot data.",
  "keywords": [
    "cli",
    "deps-xscan",
    "finografic",
    "genx:type:cli"
  ],
  "homepage": "https://github.com/finografic/deps-xscan",
  "bugs": {
    "url": "https://github.com/finografic/deps-xscan/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/deps-xscan.git"
  },
  "bin": {
    "deps-xscan": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "link": "pnpm build && pnpm link --global",
    "unlink": "pnpm unlink --global",
    "---------- SCANNER": "---------------------------------------------------",
    "scan": "tsx src/cli.ts scan",
    "scan:no-cache": "tsx src/cli.ts scan --no-cache --verbose",
    "·········· DEMO": "······················································",
    "demo:dev": "pnpm --dir demo dev",
    "demo:build": "pnpm --dir demo build",
    "demo:release:check": "pnpm --filter @finografic/deps-xscan-demo release:check",
    "demo:release:github:patch": "pnpm --filter @finografic/deps-xscan-demo release:github:patch",
    "demo:release:github:minor": "pnpm --filter @finografic/deps-xscan-demo release:github:minor",
    "demo:release:github:major": "pnpm --filter @finografic/deps-xscan-demo release:github:major",
    "demo:release:publish": "pnpm --filter @finografic/deps-xscan-demo release:publish",
    "·········· TESTING": "···················································",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "·········· LINTING": "···················································",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix",
    "lint:md": "md-lint",
    "lint:md:fix": "md-lint --fix",
    "lint:ci": "oxlint -c oxlint.config.ts --quiet",
    "·········· FORMATTING": "················································",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt",
    "·········· PUBLISH:GITHUB": "············································",
    "release:github:patch": "pnpm run release:check && pnpm version patch && git push --follow-tags",
    "release:github:minor": "pnpm run release:check && pnpm version minor && git push --follow-tags",
    "release:github:major": "pnpm run release:check && pnpm version major && git push --follow-tags",
    "release:check": "pnpm format:check && pnpm lint:fix && pnpm typecheck && pnpm test:run",
    "release:publish": "pnpm publish --registry https://npm.pkg.github.com",
    "·········· REGISTRIES": "················································",
    "view:registry:github": "pnpm view @finografic/deps-xscan --registry=https://npm.pkg.github.com",
    "view:registry:github:demo": "pnpm view @finografic/deps-xscan-demo --registry=https://npm.pkg.github.com",
    "·········· PACKAGES": "··················································",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest && pnpm update oxfmt --latest && pnpm update oxlint --latest",
    "update:cli-kit": "pnpm update @finografic/cli-kit --latest",
    "update:md-lint": "pnpm update @finografic/md-lint --latest",
    "update:deps:all": "pnpm update --latest",
    "·········· UTILS": "·····················································",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepack": "pnpm build",
    "prepare": "husky",
    "dev:cli": "NODE_ENV=development tsx src/cli.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@finografic/cli-kit": "^1.4.0",
    "js-yaml": "^4.1.1",
    "node-fetch": "^3.3.2",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@finografic/md-lint": "^0.16.6",
    "@finografic/oxc-config": "^2.8.2",
    "@finografic/project-scripts": "^1.5.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "24.12.0",
    "@types/semver": "^7.5.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.16.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "md-lint --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@10.33.4",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=24.16.0",
    "pnpm": "10.x"
  }
}
