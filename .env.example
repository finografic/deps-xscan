# GitHub PAT for Dependabot alerts and higher API rate limits.
# Place this file in the project you are scanning (--project), not in the xscan install directory.
#
# Auto-detected (first non-empty wins): NPM_TOKEN, GH_TOKEN, GITHUB_TOKEN
# Override: xscan --github-token-env MY_VAR
# File fallback: GITHUB_TOKEN_FILE=/path/to/token
NPM_TOKEN=
